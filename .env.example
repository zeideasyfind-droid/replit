# ============================================================
#  EasyFind Property Admin — Environment Variables
#  Copy this file to .env (or set each variable in Replit
#  Secrets / your shell). The app will refuse to start if any
#  of the REQUIRED variables is missing.
# ============================================================


# ── REQUIRED SECRETS ──────────────────────────────────────────
# Add these in Replit → Tools → Secrets (they must NOT be in
# source files or .replit).

# Shared admin password for the property form.
# Accepted as ?token=VALUE in the URL or Authorization: Bearer VALUE.
ADMIN_AUTH_TOKEN=Easyfind@2025

# Meta (Facebook) Graph API — long-lived system user token.
# Must have catalog_management + catalog_ads permissions.
# Generate at: https://developers.facebook.com → your app → System Users
META_ACCESS_TOKEN=your_meta_access_token_here

# WhatsApp Business Cloud API token.
# Usually the same long-lived system user token as META_ACCESS_TOKEN,
# but kept separate so they can be rotated independently.
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here

# Cloudinary upload credentials.
# Find at: https://cloudinary.com/console → API Keys
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# Google Maps API key (server-side; currently reserved for future geocoding).
# Enable "Maps JavaScript API" and "Geocoding API" in Google Cloud Console.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Session secret — reserved for the planned cookie-based login page (Task #2).
# Set to any long random string now so it's ready when login is implemented.
SESSION_SECRET=your_random_session_secret_here


# ── NON-SENSITIVE CONFIG ──────────────────────────────────────
# These are already set in .replit [userenv.shared] and do NOT
# need to be in Replit Secrets. Listed here for reference so a
# new environment can be configured from a single file.

# Cloudinary cloud name (the subdomain of your Cloudinary account).
CLOUDINARY_CLOUD_NAME=dcvwsclyc

# Meta App ID (not secret — visible in the Facebook developer dashboard).
META_APP_ID=1897860514267804

# Meta Commerce Catalog ID — the catalog where property listings are pushed.
# Find at: https://business.facebook.com → Commerce Manager → Catalogs
META_CATALOG_ID=1674288420320509

# WhatsApp Business phone number ID (not the phone number itself — the ID).
# Find at: Facebook Developer Console → WhatsApp → Getting Started
WHATSAPP_PHONE_NUMBER_ID=1085572627976973

# The WhatsApp number that receives confirmation messages after each listing.
# Format: country code + number, no + or spaces (e.g. 919148338801 for +91 91 4833 8801).
WHATSAPP_RECIPIENT_NUMBER=919148338801


# ── OPTIONAL ──────────────────────────────────────────────────

# Set to true to skip all real API calls (Cloudinary, Meta, WhatsApp).
# Useful for local development and UI testing.
# MOCK_MODE=true

# Override the server port (default: 5000).
# PORT=5000
